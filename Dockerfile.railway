FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir ".[dev]"

COPY . .

RUN mkdir -p data/generated && chmod +x railway_start.sh

ENV API_PORT=8000
ENV NDA_API_URL=http://127.0.0.1:8000/api

# Railway assigns PORT dynamically — Streamlit listens on it
EXPOSE ${PORT:-8501}
EXPOSE 8000

CMD ["./railway_start.sh"]
